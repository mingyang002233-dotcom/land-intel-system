# 環境變數與金鑰（絕對不可進 Git）
.env
.env.*
*.env
secrets.json
token.txt
# 範本檔案例外，允許進 Git
!.env.example

# 資料庫
db/*.db
db/*.db-shm
db/*.db-wal
data/*.db
data/*.db-shm
data/*.db-wal
data/database/*.db
data/database/*.db-shm
data/database/*.db-wal
# 土地主清冊 Excel（含個資，不進 git）
data/land_master/*.xlsx
data/land_master/*.xls
*.xlsx
*.xls

# excel土地資料維護 工作區（Desktop，含個資與大型檔案，不進 git）
excel土地資料維護/output/
excel土地資料維護/backup/
excel土地資料維護/logs/
excel土地資料維護/最新完成版/
excel土地資料維護/input/
excel土地資料維護/電傳待解析/
excel土地資料維護/電傳已完成/
excel土地資料維護/電傳錯誤/

# 執行期產生的 JSON 資料（keyword trends 等）
data/*.json

# CSV 原始資料（體積大，不入版控）
csv/

# Log 檔
logs/
*.log

# 輸出報表
output/
outputs/

# Python 暫存
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# macOS
.DS_Store

# 暫存 / 備份
*.tmp
*.bak
*.swp
*.orig

# IDE
.vscode/
.idea/
