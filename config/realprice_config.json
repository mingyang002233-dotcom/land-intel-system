  },

  "category_rules_comment": "用於 parser 輸出 target_category（規則式分類；不過濾）。順序由上到下，首符合即套用。",
  "category_rules": [
    { "name": "車位",   "if_target_contains": ["車位"] },
    { "name": "預售",   "if_source_kind": "presale" },
    { "name": "租賃",   "if_source_kind": "rent" },
    { "name": "房屋",   "if_target_contains": ["房地"] },
    { "name": "工業",   "if_zone_contains": ["工業", "乙工", "丁工", "甲工"] },
    { "name": "農地",   "if_zone_contains": ["農業", "農牧", "農地", "一般農業區", "特定農業區", "山坡地保育"] },
    { "name": "建地",   "if_target_contains": ["土地"], "if_zone_contains": ["住", "商", "建", "甲建", "乙建", "丁建", "鄉村區"] },
    { "name": "土地",   "if_target_contains": ["土地"] },
    { "name": "建物",   "if_target_contains": ["建物"] }
  ],

  "special_note_terms_comment": "用於 query 層判斷 target_category='特殊' 或附加 is_special 標籤（非過濾）。",
  "special_note_terms": [
    "贈與", "繼承", "交換", "親友交易", "特殊關係", "異常",
    "協議價購", "政府機關標讓售", "容積代金基金採購", "未登記建物",
    "包含公共設施保留地", "瑕疵", "凶宅", "輻射屋", "海砂屋"
  ],

  "files": {
    "csv_dir": "../csv/lvr_landcsv",
    "db_file": "../db/land_intel.db",
    "log_dir": "../logs"
  },

  "engine": {
    "allow_llm": false,
    "allow_worth_score": false,
    "allow_titledeed_judgement": false,
    "filter_at_parse": false
  }
}
