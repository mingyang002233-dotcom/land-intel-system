TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Public tunnel provider for Telegram/n8n HTTP access to the local API.
# Recommended for v1.1 stable operation: ngrok with a reserved static domain.
# Fallback provider remains localtunnel.
PUBLIC_TUNNEL_PROVIDER=ngrok
NGROK_DOMAIN=your-static-domain.ngrok-free.app
API_BASE_URL=https://your-static-domain.ngrok-free.app
LOCAL_API_PORT=5055

# localtunnel fallback example:
# PUBLIC_TUNNEL_PROVIDER=localtunnel
# API_BASE_URL=https://solid-results-remain.loca.lt
